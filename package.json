{
  "name": "agentlint",
  "version": "1.0.0",
  "description": "Cross-platform linter for AI agent configs (CLAUDE.md, AGENTS.md, .cursorrules, MCP). Dead refs, conflicts, security. CI-ready SARIF output.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentlint": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node dist/cli.js lint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "linting",
    "validation",
    "claude",
    "mcp",
    "config",
    "static-analysis",
    "typescript",
    "sarif",
    "ai-agent",
    "claude-code",
    "agents-md"
  ],
  "author": "JSLEEKR",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "fast-glob": "^3.3.0",
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}
